---
import '../styles/global.css';
import { getLangFromUrl, useTranslations, getAlternateLinks } from '../i18n/utils';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const alternateLinks = getAlternateLinks(Astro.url.pathname);

const {
  title = t('meta.home.title'),
  description = t('meta.home.description'),
  keywords = t('meta.keywords'),
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const localeMap: Record<string, string> = { en: 'en_US', tr: 'tr_TR', de: 'de_DE' };
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Ahmet Hamdi Kılıç" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl.href} />

    {alternateLinks.map(({ lang: altLang, href }) => (
      <link rel="alternate" hreflang={altLang} href={new URL(href, Astro.site).href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL('/en/', Astro.site).href} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content="AHK - Shopify Developer" />
    <meta property="og:locale" content={localeMap[lang]} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/png" href="/images/ahk-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "ProfessionalService",
          "@id": `${Astro.site}#business`,
          "name": "AHK - Shopify Development",
          "url": Astro.site?.href,
          "logo": new URL('/images/ahk-logo.png', Astro.site).href,
          "founder": { "@id": `${Astro.site}#person` },
          "areaServed": ["TR", "DE", "US", "GB"],
          "serviceType": ["Shopify Store Development", "Shopify App Development", "E-commerce Integration", "Platform Migration"],
          "knowsLanguage": ["tr", "en", "de"],
          "sameAs": ["https://github.com/ahmethamdi", "https://www.linkedin.com/in/ahmet-hamdi-kilic/", "https://x.com/kaleciolmam"],
        },
        {
          "@type": "Person",
          "@id": `${Astro.site}#person`,
          "name": "Ahmet Hamdi Kılıç",
          "jobTitle": "Senior Shopify Developer",
          "url": Astro.site?.href,
          "address": { "@type": "PostalAddress", "addressLocality": "Korschenbroich", "addressCountry": "DE" },
          "knowsAbout": ["Shopify", "Liquid", "JavaScript", "React", "Node.js", "Plentymarkets", "Shopware"],
          "knowsLanguage": ["tr", "en", "de"],
          "sameAs": ["https://github.com/ahmethamdi", "https://www.linkedin.com/in/ahmet-hamdi-kilic/"],
        },
        {
          "@type": "WebSite",
          "@id": `${Astro.site}#website`,
          "url": Astro.site?.href,
          "name": "AHK - Shopify Developer",
          "publisher": { "@id": `${Astro.site}#person` },
          "inLanguage": ["en", "tr", "de"],
        },
      ],
    })} />
  </head>
  <body class="bg-dark-900 text-white font-body antialiased overflow-x-hidden noise-bg">
    <div class="page-transition fixed inset-0 bg-lime z-[100] pointer-events-none" id="page-transition"></div>
    <Header />
    <main><slot /></main>
    <Footer />

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      gsap.registerPlugin(ScrollTrigger);

      // Page enter
      const tr = document.getElementById('page-transition');
      if (tr) gsap.fromTo(tr, { scaleY: 1 }, { scaleY: 0, duration: 0.8, ease: 'power4.inOut', transformOrigin: 'top', delay: 0.1 });

      // Reveals
      document.querySelectorAll('.reveal-up, .reveal-left, .reveal-right, .reveal-scale, .reveal-rotate').forEach((el) => {
        gsap.to(el, { opacity: 1, x: 0, y: 0, scale: 1, rotation: 0, duration: 1, ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' } });
      });

      // Stagger
      document.querySelectorAll('.stagger-container').forEach((c) => {
        gsap.from(c.querySelectorAll('.stagger-item'), { y: 60, opacity: 0, duration: 0.8, stagger: 0.12, ease: 'power3.out',
          scrollTrigger: { trigger: c, start: 'top 80%', toggleActions: 'play none none none' } });
      });

      // Counters
      document.querySelectorAll('.counter').forEach((el) => {
        const target = parseInt(el.getAttribute('data-target') || '0');
        const suffix = el.getAttribute('data-suffix') || '';
        ScrollTrigger.create({ trigger: el, start: 'top 90%', once: true,
          onEnter: () => { gsap.to({ val: 0 }, { val: target, duration: 2, ease: 'power2.out',
            onUpdate: function() { (el as HTMLElement).textContent = Math.round(this.targets()[0].val) + suffix; } }); } });
      });

      // Header scroll
      const header = document.querySelector('header');
      if (header) ScrollTrigger.create({ start: 'top -80',
        onUpdate: (s) => { if (s.direction === 1) header.classList.add('header-scrolled'); if (s.scroll() < 80) header.classList.remove('header-scrolled'); } });

      // Page transitions
      document.querySelectorAll('a[href^="/"]').forEach((link) => {
        link.addEventListener('click', (e) => {
          const href = (link as HTMLAnchorElement).getAttribute('href');
          if (!href || href === window.location.pathname) return;
          e.preventDefault();
          const t = document.getElementById('page-transition');
          if (t) gsap.fromTo(t, { scaleY: 0 }, { scaleY: 1, duration: 0.5, ease: 'power4.inOut', transformOrigin: 'bottom', onComplete: () => { window.location.href = href; } });
          else window.location.href = href!;
        });
      });
    </script>
  </body>
</html>

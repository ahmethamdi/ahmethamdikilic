---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../../i18n/utils';
import { blogPosts } from '../../../data/blog';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('meta.blog.title')} description={t('meta.blog.description')}>

  <!-- Hero -->
  <section class="relative pt-32 pb-20 sm:pt-40 sm:pb-28 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(200,217,38,0.06)_0%,_transparent_50%)]"></div>
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="flex items-center gap-3 mb-6 reveal-up">
        <div class="w-12 h-[2px] bg-lime"></div>
        <span class="text-[13px] uppercase tracking-[0.3em] text-lime font-medium">{t('blog.tag')}</span>
      </div>
      <h1 class="font-heading text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold text-white leading-[0.95] mb-8 reveal-up">{t('blog.title')}</h1>
      <p class="max-w-2xl text-lg text-gray-300 leading-relaxed reveal-up">{t('blog.subtitle')}</p>
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="py-20 sm:py-28">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-container">
        {blogPosts.map((post) => (
          <a href={getLocalizedPath(lang, `/blog/${post.slug}/`)} class="stagger-item blog-card group rounded-3xl bg-dark-800 border border-dark-700 hover:border-lime/30 overflow-hidden block">
            <!-- Gradient header -->
            <div class="relative h-48 sm:h-56 overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-br from-lime/20 via-lime/5 to-dark-800"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-center">
                  <span class="inline-block px-3 py-1.5 text-[11px] font-bold bg-lime/20 text-lime rounded-full uppercase tracking-wider mb-3">{post.category[lang]}</span>
                  <div class="text-6xl sm:text-7xl font-heading font-bold text-dark-600/30 select-none">{post.readTime}min</div>
                </div>
              </div>
              <!-- Date badge -->
              <div class="absolute top-4 right-4 px-3 py-1.5 bg-dark-900/80 backdrop-blur-sm rounded-full text-[11px] text-gray-300 font-medium">
                {new Date(post.date).toLocaleDateString(lang === 'tr' ? 'tr-TR' : lang === 'de' ? 'de-DE' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </div>
            </div>
            <!-- Content -->
            <div class="p-6 sm:p-8">
              <h2 class="font-heading text-xl sm:text-2xl font-bold text-white mb-3 group-hover:text-lime transition-colors duration-300 leading-tight line-clamp-2">{post.title[lang]}</h2>
              <p class="text-gray-300 text-sm leading-relaxed mb-5 line-clamp-3">{post.excerpt[lang]}</p>
              <div class="flex flex-wrap gap-2 mb-5">
                {post.tags.slice(0, 3).map((tag) => (
                  <span class="px-2.5 py-1 text-[11px] font-medium text-gray-300 bg-dark-700 border border-dark-600 rounded-full">{tag}</span>
                ))}
              </div>
              <div class="flex items-center gap-2 text-lime font-heading font-bold text-sm uppercase tracking-wider group/link">
                {t('blog.read')}
                <svg class="w-4 h-4 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter / Social CTA -->
  <section class="py-28 sm:py-36 border-t border-dark-700">
    <div class="max-w-[800px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="rounded-3xl bg-dark-800 border border-dark-700 relative overflow-hidden reveal-up">
        <div class="absolute top-0 left-0 w-32 h-32 border-t-2 border-l-2 border-lime/20 rounded-tl-3xl"></div>
        <div class="absolute bottom-0 right-0 w-32 h-32 border-b-2 border-r-2 border-lime/20 rounded-br-3xl"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-lime/5 via-transparent to-transparent"></div>

        <div class="relative z-10 p-12 sm:p-16 text-center">
          <div class="w-20 h-20 rounded-3xl bg-lime/10 flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-lime" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
          </div>
          <h2 class="font-heading text-3xl sm:text-4xl font-bold text-white mb-4">{t('footer.connect')}</h2>
          <p class="text-gray-300 text-lg leading-relaxed mb-8 max-w-md mx-auto">{t('blog.coming.desc')}</p>

          <div class="flex items-center justify-center gap-3">
            <a href="https://github.com/ahmethamdi" target="_blank" rel="noopener noreferrer" class="group w-14 h-14 rounded-2xl bg-dark-900 border border-dark-700 hover:border-lime/30 flex items-center justify-center text-gray-300 hover:text-lime transition-all duration-300 hover:-translate-y-1">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/ahmet-hamdi-kilic/" target="_blank" rel="noopener noreferrer" class="group w-14 h-14 rounded-2xl bg-dark-900 border border-dark-700 hover:border-lime/30 flex items-center justify-center text-gray-300 hover:text-lime transition-all duration-300 hover:-translate-y-1">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="https://x.com/kaleciolmam" target="_blank" rel="noopener noreferrer" class="group w-14 h-14 rounded-2xl bg-dark-900 border border-dark-700 hover:border-lime/30 flex items-center justify-center text-gray-300 hover:text-lime transition-all duration-300 hover:-translate-y-1">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

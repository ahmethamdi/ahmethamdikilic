---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';
import { projects, referenceStores } from '../../data/projects';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const featuredProjects = projects.slice(0, 3);

const clientLogos = [
  'dripfy-1.png', 'fisher-1.png', 'itech-1.png', 'logo-1-1.png',
  'logo-2.png', 'logo-3.png', 'logo-4.png', 'logo-5.png',
  'logo-6.png', 'logo-7.png', 'logo-8.png', 'logo-9.png',
  'logo-10.png', 'logo2.png', 'olcay-1.png', 'logo-4-1.png',
];

const serviceImages = [
  { src: '/images/services/Custom-Shopify-Theme-Development.jpg', title: 'services.theme.title' as const },
  { src: '/images/services/Shopify-E-Commerce-Automation-API-Solutions.jpg', title: 'services.app.title' as const },
  { src: '/images/services/Web-Design-Frontend-Development.jpg', title: 'services.integration.title' as const },
  { src: '/images/services/Branding-Product-Design-service.jpg', title: 'services.speed.title' as const },
];

const featuredRefs = referenceStores.slice(0, 6);
---

<BaseLayout title={t('meta.home.title')} description={t('meta.home.description')}>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO — Full viewport, immersive, award-quality
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex flex-col justify-center overflow-hidden" id="hero">
    <!-- Animated background layers -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(200,217,38,0.1)_0%,_transparent_50%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(200,217,38,0.06)_0%,_transparent_50%)]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(rgba(200,217,38,0.015)_1px,transparent_1px),linear_gradient(90deg,rgba(200,217,38,0.015)_1px,transparent_1px)] bg-[size:80px_80px]" id="hero-grid"></div>
      <!-- Floating orbs -->
      <div class="absolute top-1/4 right-1/4 w-[500px] h-[500px] rounded-full bg-lime/[0.03] blur-[120px] animate-float-slow"></div>
      <div class="absolute bottom-1/3 left-1/6 w-[300px] h-[300px] rounded-full bg-lime/[0.04] blur-[80px] animate-float-delayed"></div>
    </div>

    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 w-full pt-32 pb-20">
      <!-- Top label -->
      <div class="flex items-center gap-3 mb-8 reveal-up">
        <div class="w-12 h-[2px] bg-lime"></div>
        <span class="text-[13px] uppercase tracking-[0.3em] text-lime font-medium">{t('hero.greeting')}</span>
      </div>

      <!-- Name — MASSIVE -->
      <h1 class="font-heading font-bold leading-[0.9] mb-8 reveal-up">
        <span class="block text-[clamp(3rem,10vw,9rem)] text-white">Ahmet Hamdi</span>
        <span class="block text-[clamp(3rem,10vw,9rem)] text-stroke">Kılıç</span>
      </h1>

      <!-- Title + Description -->
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-end mb-16">
        <div class="reveal-up">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-lime/10 border border-lime/20 rounded-full mb-6">
            <span class="w-2 h-2 bg-lime rounded-full animate-pulse"></span>
            <span class="text-sm text-lime font-medium">{t('contact.info.available')}</span>
          </div>
          <h2 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-semibold text-white leading-tight">
            {t('hero.title')}
          </h2>
        </div>
        <div class="reveal-up">
          <p class="text-gray-300 text-lg leading-relaxed mb-8">{t('hero.subtitle')}</p>
          <div class="flex flex-wrap gap-4">
            <a href={getLocalizedPath(lang, '/portfolio/')} class="group inline-flex items-center gap-3 px-8 py-4 bg-lime text-dark-900 font-heading font-bold text-sm uppercase tracking-wider rounded-full hover:bg-lime-light transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(200,217,38,0.4)]">
              {t('hero.cta.primary')}
              <svg class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
            </a>
            <a href={getLocalizedPath(lang, '/contact/')} class="group inline-flex items-center gap-3 px-8 py-4 border-2 border-dark-500 text-white font-heading font-bold text-sm uppercase tracking-wider rounded-full hover:border-lime hover:text-lime transition-all duration-300">
              {t('hero.cta.secondary')}
            </a>
          </div>
        </div>
      </div>

      <!-- Stats — Big numbers -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-dark-600 rounded-2xl overflow-hidden reveal-up">
        <div class="bg-dark-900 p-8 lg:p-10 text-center group hover:bg-dark-800 transition-colors duration-500">
          <div class="text-5xl sm:text-6xl lg:text-7xl font-bold font-heading text-lime mb-2 group-hover:scale-110 transition-transform duration-500">
            <span class="counter" data-target="3" data-suffix="+">0</span>
          </div>
          <p class="text-sm text-gray-300 uppercase tracking-wider">{t('hero.stats.experience')}</p>
        </div>
        <div class="bg-dark-900 p-8 lg:p-10 text-center group hover:bg-dark-800 transition-colors duration-500">
          <div class="text-5xl sm:text-6xl lg:text-7xl font-bold font-heading text-lime mb-2 group-hover:scale-110 transition-transform duration-500">
            <span class="counter" data-target="50" data-suffix="+">0</span>
          </div>
          <p class="text-sm text-gray-300 uppercase tracking-wider">{t('hero.stats.projects')}</p>
        </div>
        <div class="bg-dark-900 p-8 lg:p-10 text-center group hover:bg-dark-800 transition-colors duration-500">
          <div class="text-5xl sm:text-6xl lg:text-7xl font-bold font-heading text-lime mb-2 group-hover:scale-110 transition-transform duration-500">
            <span class="counter" data-target="30" data-suffix="+">0</span>
          </div>
          <p class="text-sm text-gray-300 uppercase tracking-wider">{t('hero.stats.clients')}</p>
        </div>
        <div class="bg-dark-900 p-8 lg:p-10 text-center group hover:bg-dark-800 transition-colors duration-500">
          <div class="text-5xl sm:text-6xl lg:text-7xl font-bold font-heading text-lime mb-2 group-hover:scale-110 transition-transform duration-500">
            <span class="counter" data-target="3">0</span>
          </div>
          <p class="text-sm text-gray-300 uppercase tracking-wider">{t('hero.stats.apps')}</p>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
      <span class="text-[10px] uppercase tracking-[0.3em] text-gray-500 font-medium">{t('hero.scroll')}</span>
      <div class="w-[1px] h-12 bg-gradient-to-b from-transparent via-lime to-transparent animate-pulse"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       CLIENT LOGOS — GRID LAYOUT
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 sm:py-28 border-y border-dark-700 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(200,217,38,0.03)_0%,_transparent_70%)]"></div>
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <!-- Section header -->
      <div class="text-center mb-14 reveal-up">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-12 h-[2px] bg-lime"></div>
          <span class="text-[13px] uppercase tracking-[0.3em] text-lime font-medium">{t('portfolio.tag')}</span>
          <div class="w-12 h-[2px] bg-lime"></div>
        </div>
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-white">{t('hero.stats.clients')}</h2>
      </div>

      <!-- Logo Grid -->
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-8 gap-6 sm:gap-8 stagger-container">
        {clientLogos.map((logo) => (
          <div class="stagger-item flex items-center justify-center p-4 sm:p-6 rounded-2xl bg-dark-800/50 border border-dark-700/50 hover:border-lime/20 hover:bg-dark-800 transition-all duration-500 group">
            <img
              src={`/images/clients/${logo}`}
              alt="Client"
              class="h-8 sm:h-10 lg:h-12 w-auto max-w-full opacity-40 group-hover:opacity-100 transition-all duration-500 grayscale group-hover:grayscale-0 group-hover:scale-110"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       SERVICES — Bold layout with images
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-28 sm:py-36 relative">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <!-- Section label -->
      <div class="flex items-center justify-between mb-16">
        <div class="reveal-up">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-[2px] bg-lime"></div>
            <span class="text-[13px] uppercase tracking-[0.3em] text-lime font-medium">{t('services.tag')}</span>
          </div>
          <h2 class="font-heading text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white">
            {t('services.title')}
          </h2>
        </div>
        <a href={getLocalizedPath(lang, '/services/')} class="hidden md:inline-flex items-center gap-2 px-6 py-3 border border-dark-500 text-white font-heading font-bold text-[13px] uppercase tracking-wider rounded-full hover:border-lime hover:text-lime transition-all duration-300 reveal-up">
          {t('services.tag')}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
        </a>
      </div>

      <!-- Service cards with images -->
      <div class="grid md:grid-cols-2 gap-6 stagger-container">
        {serviceImages.map(({ src, title }, i) => (
          <a href={getLocalizedPath(lang, '/services/')} class="stagger-item group relative h-[400px] sm:h-[500px] rounded-3xl overflow-hidden">
            <img src={src} alt={t(title)} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-dark-900 via-dark-900/50 to-transparent group-hover:via-dark-900/30 transition-all duration-700"></div>
            <div class="absolute bottom-0 left-0 right-0 p-8 sm:p-10">
              <span class="inline-block px-3 py-1 bg-lime/20 backdrop-blur-sm text-lime text-xs font-medium uppercase tracking-wider rounded-full mb-4">0{i + 1}</span>
              <h3 class="font-heading text-2xl sm:text-3xl font-bold text-white group-hover:text-lime transition-colors duration-300">{t(title)}</h3>
            </div>
            <div class="absolute top-6 right-6 w-12 h-12 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 group-hover:scale-110">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       ABOUT STRIP — Lime background section
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative py-28 sm:py-32 bg-lime overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(0,0,0,0.02)_25%,transparent_25%,transparent_50%,rgba(0,0,0,0.02)_50%,rgba(0,0,0,0.02)_75%,transparent_75%)] bg-[length:80px_80px]"></div>

    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="reveal-up">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-[2px] bg-dark-900"></div>
            <span class="text-[13px] uppercase tracking-[0.3em] text-dark-900/60 font-medium">{t('about.tag')}</span>
          </div>
          <h2 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold text-dark-900 mb-6 leading-tight">
            {t('about.title')}
          </h2>
          <p class="text-lg text-dark-900/70 leading-relaxed mb-8">{t('about.intro')}</p>
          <a href={getLocalizedPath(lang, '/about/')} class="group inline-flex items-center gap-3 px-8 py-4 bg-dark-900 text-lime font-heading font-bold text-sm uppercase tracking-wider rounded-full hover:scale-105 transition-all duration-300 hover:shadow-[0_0_40px_rgba(10,10,10,0.4)]">
            {t('about.tag')}
            <svg class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
          </a>
        </div>
        <div class="relative reveal-right">
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-dark-900 rounded-2xl p-8 text-center hover:scale-105 transition-transform duration-300">
              <div class="text-4xl sm:text-5xl font-bold font-heading text-lime mb-2">3+</div>
              <p class="text-sm text-gray-300">{t('hero.stats.experience')}</p>
            </div>
            <div class="bg-dark-900 rounded-2xl p-8 text-center hover:scale-105 transition-transform duration-300">
              <div class="text-4xl sm:text-5xl font-bold font-heading text-lime mb-2">50+</div>
              <p class="text-sm text-gray-300">{t('hero.stats.projects')}</p>
            </div>
            <div class="bg-dark-900 rounded-2xl p-8 text-center col-span-2 hover:scale-[1.02] transition-transform duration-300">
              <img src="/images/ahk-logo.png" alt="AHK" class="w-16 h-16 mx-auto mb-4 rounded-xl" />
              <p class="text-lime font-heading font-bold text-lg">Shopify Partner</p>
              <p class="text-sm text-gray-300 mt-1">Certified Developer</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       PORTFOLIO — Featured Projects
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-28 sm:py-36 relative">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <!-- Section header -->
      <div class="flex items-center justify-between mb-16">
        <div class="reveal-up">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-[2px] bg-lime"></div>
            <span class="text-[13px] uppercase tracking-[0.3em] text-lime font-medium">{t('portfolio.tag')}</span>
          </div>
          <h2 class="font-heading text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white">
            {t('portfolio.title')}
          </h2>
        </div>
        <a href={getLocalizedPath(lang, '/portfolio/')} class="hidden md:inline-flex items-center gap-2 px-6 py-3 border border-dark-500 text-white font-heading font-bold text-[13px] uppercase tracking-wider rounded-full hover:border-lime hover:text-lime transition-all duration-300 reveal-up">
          {t('portfolio.tag')}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
        </a>
      </div>

      <!-- Project list — horizontal cards -->
      <div class="space-y-6 stagger-container">
        {featuredProjects.map((project, i) => (
          <div class="stagger-item group relative rounded-3xl bg-dark-800 border border-dark-700 hover:border-lime/30 transition-all duration-500 overflow-hidden hover:shadow-[0_0_60px_rgba(200,217,38,0.06)]">
            <div class="grid lg:grid-cols-12 gap-0">
              <!-- Image side -->
              <div class="lg:col-span-5 relative h-64 lg:h-auto min-h-[320px] bg-dark-700 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-lime/10 via-lime/5 to-transparent group-hover:from-lime/15 transition-all duration-700"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <span class="text-[120px] sm:text-[160px] font-heading font-bold text-dark-600/50 select-none group-hover:text-lime/10 transition-colors duration-700">0{i + 1}</span>
                </div>
                <div class="absolute top-6 left-6 flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="px-3 py-1.5 text-xs font-bold bg-dark-900/80 text-lime rounded-full backdrop-blur-sm uppercase tracking-wider">{tag}</span>
                  ))}
                </div>
              </div>
              <!-- Content side -->
              <div class="lg:col-span-7 p-8 sm:p-10 lg:p-12 flex flex-col justify-center">
                <h3 class="font-heading text-2xl sm:text-3xl font-bold text-white mb-4 group-hover:text-lime transition-colors duration-300">{project.title[lang]}</h3>
                <p class="text-gray-300 leading-relaxed mb-6">{project.description[lang]}</p>
                <div class="flex flex-wrap gap-2 mb-6">
                  {project.tech.map((tech) => (
                    <span class="px-3 py-1.5 text-xs font-medium text-gray-300 bg-dark-700 border border-dark-600 rounded-full">{tech}</span>
                  ))}
                </div>
                <a href={getLocalizedPath(lang, '/portfolio/')} class="inline-flex items-center gap-2 text-lime font-heading font-bold text-sm uppercase tracking-wider group/link">
                  {t('portfolio.view')}
                  <svg class="w-4 h-4 group-hover/link:translate-x-1 group-hover/link:-translate-y-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       REFERENCE STORES — Client Showcases with Mockups
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-28 sm:py-36 relative border-t border-dark-700">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <!-- Section header -->
      <div class="text-center mb-16 reveal-up">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="w-12 h-[2px] bg-lime"></div>
          <span class="text-[13px] uppercase tracking-[0.3em] text-lime font-medium">{t('portfolio.tag')}</span>
          <div class="w-12 h-[2px] bg-lime"></div>
        </div>
        <h2 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold text-white mb-4">
          {t('hero.stats.clients')}
        </h2>
        <p class="text-gray-300 text-lg max-w-2xl mx-auto">{t('portfolio.subtitle')}</p>
      </div>

      <!-- Reference grid — award-quality layout -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-container">
        {featuredRefs.map((ref) => (
          <div class="stagger-item group rounded-3xl bg-dark-800 border border-dark-700 hover:border-lime/30 transition-all duration-500 overflow-hidden hover:shadow-[0_0_60px_rgba(200,217,38,0.06)] hover:-translate-y-2">
            <!-- Mockup Image -->
            <div class="relative aspect-[16/10] overflow-hidden">
              <img
                src={ref.image}
                alt={ref.name}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-dark-800 via-transparent to-transparent opacity-60"></div>
              <!-- Industry badge -->
              <div class="absolute top-4 left-4">
                <span class="px-3 py-1.5 text-[11px] font-bold bg-dark-900/80 text-lime rounded-full backdrop-blur-sm uppercase tracking-wider">{ref.industry[lang]}</span>
              </div>
              <!-- Visit arrow -->
              <div class="absolute top-4 right-4 w-10 h-10 rounded-full bg-lime/20 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300">
                <svg class="w-4 h-4 text-lime" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
              </div>
            </div>
            <!-- Content -->
            <div class="p-6 sm:p-8">
              <h3 class="font-heading text-xl font-bold text-white mb-2 group-hover:text-lime transition-colors duration-300">{ref.name}</h3>
              <p class="text-gray-300 text-sm leading-relaxed mb-4 line-clamp-3">{ref.description[lang]}</p>
              <div class="flex flex-wrap gap-2">
                {ref.tags.map((tag) => (
                  <span class="px-2.5 py-1 text-[11px] font-medium text-gray-300 bg-dark-700 border border-dark-600 rounded-full">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- View all button -->
      <div class="text-center mt-12 reveal-up">
        <a href={getLocalizedPath(lang, '/portfolio/')} class="group inline-flex items-center gap-3 px-10 py-5 bg-lime text-dark-900 font-heading font-bold text-sm uppercase tracking-wider rounded-full hover:bg-lime-light transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(200,217,38,0.4)]">
          {t('hero.cta.primary')}
          <svg class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       MARQUEE TEXT
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-8 overflow-hidden border-y border-dark-700 marquee-container">
    <div class="flex whitespace-nowrap">

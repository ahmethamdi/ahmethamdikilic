---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../../i18n/utils';
import { blogPosts } from '../../../data/blog';

export function getStaticPaths() {
  return blogPosts.map((post) => ({ params: { slug: post.slug } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { slug } = Astro.params;
const post = blogPosts.find((p) => p.slug === slug)!;
const otherPosts = blogPosts.filter((p) => p.slug !== slug).slice(0, 2);

function markdownToHtml(md: string): string {
  let html = md;

  // Headers
  html = html.replace(/^## (.+)$/gm, '<h2 class="font-heading text-3xl sm:text-4xl font-bold text-white mt-16 mb-6 leading-tight">$1</h2>');
  html = html.replace(/^### (.+)$/gm, '<h3 class="font-heading text-xl sm:text-2xl font-bold text-white mt-10 mb-4">$1</h3>');

  // Bold
  html = html.replace(/\*\*(.+?)\*\*/g, '<strong class="text-white font-semibold">$1</strong>');

  // Inline code
  html = html.replace(/`([^`]+)`/g, '<code class="px-1.5 py-0.5 bg-dark-700 text-lime text-sm rounded font-mono">$1</code>');

  // List items
  html = html.replace(/^- (.+)$/gm, '<div class="flex gap-3 mb-2"><span class="text-lime shrink-0 mt-1.5">&#8212;</span><span class="text-gray-300">$1</span></div>');

  // Numbered lists
  html = html.replace(/^(\d+)\. (.+)$/gm, '<div class="flex gap-3 mb-2"><span class="text-lime font-heading font-bold shrink-0">$1.</span><span class="text-gray-300">$2</span></div>');

  // Paragraphs (lines that don't start with < )
  const lines = html.split('\n');
  const result: string[] = [];
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) {
      result.push('');
    } else if (trimmed.startsWith('<')) {
      result.push(trimmed);
    } else {
      result.push(`<p class="text-gray-300 text-lg leading-relaxed mb-4">${trimmed}</p>`);
    }
  }

  return result.join('\n');
}

const articleHtml = markdownToHtml(post.content[lang]);
---

<BaseLayout title={post.metaTitle[lang]} description={post.metaDescription[lang]}>

  <!-- Article Header -->
  <section class="relative pt-32 pb-16 sm:pt-40 sm:pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(200,217,38,0.06)_0%,_transparent_50%)]"></div>
    <div class="relative z-10 max-w-[900px] mx-auto px-6 sm:px-8">
      <!-- Back link -->
      <a href={getLocalizedPath(lang, '/blog/')} class="inline-flex items-center gap-2 text-gray-300 hover:text-lime transition-colors mb-8 font-medium text-sm group reveal-up">
        <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
        {t('blog.back')}
      </a>

      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-4 mb-6 reveal-up">
        <span class="px-3 py-1.5 text-[11px] font-bold bg-lime/20 text-lime rounded-full uppercase tracking-wider">{post.category[lang]}</span>
        <span class="text-sm text-gray-500">
          {new Date(post.date).toLocaleDateString(lang === 'tr' ? 'tr-TR' : lang === 'de' ? 'de-DE' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
        <span class="text-sm text-gray-500">{post.readTime} min read</span>
      </div>

      <!-- Title -->
      <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold text-white leading-[1.05] mb-6 reveal-up">{post.title[lang]}</h1>

      <!-- Excerpt -->
      <p class="text-xl text-gray-300 leading-relaxed reveal-up">{post.excerpt[lang]}</p>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mt-8 reveal-up">
        {post.tags.map((tag) => (
          <span class="px-3 py-1.5 text-xs font-medium text-gray-300 bg-dark-800 border border-dark-700 rounded-full">{tag}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-[900px] mx-auto px-6 sm:px-8">
    <div class="h-px bg-dark-700"></div>
  </div>

  <!-- Article Content -->
  <section class="py-16 sm:py-20">
    <article class="max-w-[900px] mx-auto px-6 sm:px-8 reveal-up">
      <Fragment set:html={articleHtml} />
    </article>
  </section>

  <!-- Author -->
  <section class="py-12">
    <div class="max-w-[900px] mx-auto px-6 sm:px-8">
      <div class="rounded-3xl bg-dark-800 border border-dark-700 p-8 sm:p-10 reveal-up">
        <div class="flex items-center gap-6">
          <img src="/images/ahk-logo.png" alt="AHK" class="w-16 h-16 rounded-2xl" />
          <div>
            <h3 class="font-heading text-lg font-bold text-white">Ahmet Hamdi Kılıç</h3>
            <p class="text-lime text-sm">Senior Shopify Developer</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Posts -->
  {otherPosts.length > 0 && (
    <section class="py-20 sm:py-28 border-t border-dark-700">
      <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-white mb-12 reveal-up">{t('blog.tag')}</h2>
        <div class="grid md:grid-cols-2 gap-8 stagger-container">
          {otherPosts.map((relatedPost) => (
            <a href={getLocalizedPath(lang, `/blog/${relatedPost.slug}/`)} class="stagger-item blog-card group rounded-3xl bg-dark-800 border border-dark-700 hover:border-lime/30 overflow-hidden block">
              <div class="relative h-40 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-lime/15 via-lime/5 to-dark-800"></div>
                <div class="absolute top-4 left-4">
                  <span class="px-3 py-1.5 text-[11px] font-bold bg-lime/20 text-lime rounded-full uppercase tracking-wider">{relatedPost.category[lang]}</span>
                </div>
              </div>
              <div class="p-6 sm:p-8">
                <h3 class="font-heading text-lg font-bold text-white mb-2 group-hover:text-lime transition-colors line-clamp-2">{relatedPost.title[lang]}</h3>
                <p class="text-gray-300 text-sm line-clamp-2">{relatedPost.excerpt[lang]}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

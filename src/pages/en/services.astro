---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const imageServices = [
  { key: 'theme', num: '01', img: '/images/services/Custom-Shopify-Theme-Development.jpg' },
  { key: 'app', num: '02', img: '/images/services/Custom-Shopify-Theme-Development-1.jpg' },
  { key: 'integration', num: '03', img: '/images/services/Shopify-E-Commerce-Automation-API-Solutions.jpg' },
  { key: 'migration', num: '04', img: '/images/services/Web-Design-Frontend-Development.jpg' },
  { key: 'speed', num: '05', img: '/images/services/Branding-Product-Design-service.jpg' },
];

const gridServices = [
  { key: 'b2b', num: '06' },
  { key: 'checkout', num: '07' },
  { key: 'support', num: '08' },
  { key: 'seo', num: '09' },
  { key: 'metafields', num: '10' },
];
---

<BaseLayout title={t('meta.services.title')} description={t('meta.services.description')}>

  <!-- Hero -->
  <section class="relative pt-32 pb-20 sm:pt-40 sm:pb-28 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(200,217,38,0.06)_0%,_transparent_50%)]"></div>
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="flex items-center gap-3 mb-6 reveal-up">
        <div class="w-12 h-[2px] bg-lime"></div>
        <span class="text-[13px] uppercase tracking-[0.3em] text-lime font-medium">{t('services.tag')}</span>
      </div>
      <h1 class="font-heading text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold text-white leading-[0.95] mb-8 reveal-up">{t('services.title')}</h1>
      <p class="max-w-2xl text-lg text-gray-300 leading-relaxed reveal-up">{t('services.subtitle')}</p>
    </div>
  </section>

  <!-- Image Services (01-05) -->
  <section class="py-20 sm:py-28">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="space-y-20 stagger-container">
        {imageServices.map((service, index) => (
          <div class={`stagger-item grid lg:grid-cols-2 gap-8 lg:gap-16 items-center ${index % 2 === 1 ? 'lg:grid-flow-dense' : ''}`}>
            <!-- Image -->
            <div class={`relative group ${index % 2 === 1 ? 'lg:col-start-2' : ''}`}>
              <div class="aspect-[4/3] rounded-3xl overflow-hidden bg-dark-800 border border-dark-700">
                <img
                  src={service.img}
                  alt={t(`services.${service.key}.title` as any)}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
              <div class="absolute -bottom-4 -right-4 w-28 h-28 border-2 border-lime/20 rounded-3xl -z-10"></div>
            </div>

            <!-- Content -->
            <div>
              <div class="flex items-center gap-4 mb-6">
                <span class="font-heading text-7xl sm:text-8xl font-bold text-dark-700 select-none leading-none">{service.num}</span>
                <div class="w-12 h-[2px] bg-lime"></div>
              </div>
              <h2 class="font-heading text-3xl sm:text-4xl font-bold text-white mb-6">
                {t(`services.${service.key}.title` as any)}
              </h2>
              <p class="text-gray-300 leading-relaxed text-lg">
                {t(`services.${service.key}.desc` as any)}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lime accent divider -->
  <section class="relative py-28 sm:py-32 bg-lime overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(0,0,0,0.02)_25%,transparent_25%,transparent_50%,rgba(0,0,0,0.02)_50%,rgba(0,0,0,0.02)_75%,transparent_75%)] bg-[length:60px_60px]"></div>
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="reveal-up">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-[2px] bg-dark-900"></div>
            <span class="text-[13px] uppercase tracking-[0.3em] text-dark-900/60 font-medium">More Services</span>
          </div>
          <h2 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold text-dark-900 leading-[0.95]">Full-Stack E-Commerce Solutions</h2>
        </div>
        <div class="reveal-up">
          <p class="text-dark-900/80 text-lg leading-relaxed">
            Beyond core development, I provide comprehensive services covering B2B wholesale, checkout optimization, ongoing maintenance, SEO strategy, and advanced data management -- everything your Shopify store needs to scale.
          </p>
          <a href={getLocalizedPath(lang, '/contact/')} class="inline-flex items-center gap-2 mt-8 px-8 py-4 bg-dark-900 text-lime font-semibold rounded-xl hover:bg-dark-800 transition-all duration-300 group">
            <span>{t('hero.cta.secondary')}</span>
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Grid Services (06-10) -->
  <section class="py-28 sm:py-36">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-container">
        {gridServices.map((service) => (
          <div class="stagger-item group p-8 sm:p-10 rounded-3xl bg-dark-800 border border-dark-700 hover:border-lime/30 transition-all duration-500 relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-lime/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative z-10">
              <span class="font-heading text-6xl font-bold text-dark-700 group-hover:text-dark-600 transition-colors select-none block mb-6">{service.num}</span>
              <h3 class="font-heading text-xl sm:text-2xl font-bold text-white mb-4 group-hover:text-lime transition-colors">
                {t(`services.${service.key}.title` as any)}
              </h3>
              <p class="text-gray-300 leading-relaxed text-sm">
                {t(`services.${service.key}.desc` as any)}
              </p>
            </div>
          </div>
        ))}

        <!-- CTA card -->
        <a href={getLocalizedPath(lang, '/contact/')} class="stagger-item group p-8 sm:p-10 rounded-3xl bg-lime border border-lime hover:bg-lime-light transition-all duration-500 flex flex-col justify-center items-center text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(0,0,0,0.02)_25%,transparent_25%,transparent_50%,rgba(0,0,0,0.02)_50%,rgba(0,0,0,0.02)_75%,transparent_75%)] bg-[length:40px_40px]"></div>
          <div class="relative z-10">
            <svg class="w-12 h-12 text-dark-900 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/></svg>
            <h3 class="font-heading text-2xl font-bold text-dark-900 mb-2">{t('contact.title')}</h3>
            <p class="text-dark-900/70 text-sm">{t('contact.subtitle')}</p>
            <div class="mt-6 inline-flex items-center gap-2 text-dark-900 font-semibold">
              <span>{t('hero.cta.secondary')}</span>
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Page Not Found | AHK</title>
    <link rel="icon" type="image/png" href="/images/ahk-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-dark-900 text-white font-body antialiased min-h-screen flex items-center justify-center">
    <div class="text-center px-4">
      <div class="w-20 h-20 bg-lime rounded-2xl flex items-center justify-center mx-auto mb-8">
        <span class="text-black font-heading font-bold text-3xl">AHK</span>
      </div>
      <h1 class="font-heading font-bold text-8xl text-lime mb-4">404</h1>
      <p class="text-gray-300 text-lg mb-8">The page you're looking for doesn't exist.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/en/" class="px-6 py-3 bg-lime text-black font-heading font-semibold rounded-full hover:bg-lime-light transition-all duration-300">
          English
        </a>
        <a href="/tr/" class="px-6 py-3 border border-dark-500 text-white font-heading font-semibold rounded-full hover:border-lime/50 transition-all duration-300">
          Turkce
        </a>
        <a href="/de/" class="px-6 py-3 border border-dark-500 text-white font-heading font-semibold rounded-full hover:border-lime/50 transition-all duration-300">
          Deutsch
        </a>
      </div>
    </div>
  </body>
</html>

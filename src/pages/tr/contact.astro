---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('meta.contact.title')} description={t('meta.contact.description')}>

  <!-- ════════════════════════════════════════════════════════════════════
       HERO BANNER
       ════════════════════════════════════════════════════════════════════ -->
  <section class="relative pt-32 pb-20 sm:pt-40 sm:pb-24 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/3 -right-32 w-96 h-96 bg-lime/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 -left-32 w-96 h-96 bg-lime/3 rounded-full blur-3xl"></div>
      <div class="absolute inset-0 bg-[linear-gradient(rgba(200,217,38,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(200,217,38,0.03)_1px,transparent_1px)] bg-[size:4rem_4rem]"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-lime/10 border border-lime/20 mb-6 reveal-scale">
        <span class="w-1.5 h-1.5 bg-lime rounded-full"></span>
        <span class="text-xs font-medium text-lime uppercase tracking-wider">{t('contact.tag')}</span>
      </div>
      <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold mb-6 reveal-up">
        <span class="bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">{t('contact.title')}</span>
      </h1>
      <p class="max-w-2xl mx-auto text-gray-300 text-lg reveal-up">{t('contact.subtitle')}</p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       CONTACT INFO CARDS
       ════════════════════════════════════════════════════════════════════ -->
  <section class="py-24 sm:py-32">
    <div class="max-w-5xl mx-auto px-6 sm:px-8">
      <div class="grid sm:grid-cols-2 gap-6 stagger-container">
        <!-- Email -->
        <a href="mailto:ahmethamdikilic@outlook.de" class="stagger-item group p-8 rounded-2xl bg-dark-800 border border-dark-600 hover:border-lime/30 transition-all duration-500 hover:-translate-y-1 block">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 rounded-xl bg-lime/10 flex items-center justify-center flex-shrink-0 group-hover:bg-lime/20 transition-colors">
              <svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-white mb-1">{t('contact.info.email')}</h3>
              <p class="text-gray-300 group-hover:text-lime transition-colors">ahmethamdikilic@outlook.de</p>
            </div>
          </div>
        </a>

        <!-- Phone -->
        <a href="tel:+4917676798125" class="stagger-item group p-8 rounded-2xl bg-dark-800 border border-dark-600 hover:border-lime/30 transition-all duration-500 hover:-translate-y-1 block">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 rounded-xl bg-lime/10 flex items-center justify-center flex-shrink-0 group-hover:bg-lime/20 transition-colors">
              <svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-white mb-1">{t('contact.info.phone')}</h3>
              <p class="text-gray-300 group-hover:text-lime transition-colors">+49 176 76798125</p>
            </div>
          </div>
        </a>

        <!-- Location -->
        <div class="stagger-item group p-8 rounded-2xl bg-dark-800 border border-dark-600 hover:border-lime/30 transition-all duration-500 hover:-translate-y-1">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 rounded-xl bg-lime/10 flex items-center justify-center flex-shrink-0 group-hover:bg-lime/20 transition-colors">
              <svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-white mb-1">{t('contact.info.location')}</h3>
              <p class="text-gray-300">{t('contact.info.location.value')}</p>
            </div>
          </div>
        </div>

        <!-- Availability -->
        <div class="stagger-item group p-8 rounded-2xl bg-dark-800 border border-dark-600 hover:border-lime/30 transition-all duration-500 hover:-translate-y-1">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 rounded-xl bg-lime/10 flex items-center justify-center flex-shrink-0 group-hover:bg-lime/20 transition-colors">
              <svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-white mb-1">{t('contact.info.availability')}</h3>
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 bg-emerald rounded-full animate-pulse"></span>
                <p class="text-emerald font-medium">{t('contact.info.available')}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       SOCIAL LINKS & CTA
       ════════════════════════════════════════════════════════════════════ -->
  <section class="py-24 sm:py-32 relative">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-lime/5 rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 sm:px-8 text-center">
      <!-- Social Links -->
      <div class="mb-16 reveal-up">
        <h2 class="font-heading text-2xl sm:text-3xl font-bold text-white mb-8">{t('footer.connect')}</h2>
        <div class="flex items-center justify-center gap-4 stagger-container">
          <!-- GitHub -->
          <a href="https://github.com/ahmethamdi" target="_blank" rel="noopener noreferrer" class="stagger-item group w-16 h-16 rounded-2xl bg-dark-800 border border-dark-600 hover:border-lime/30 flex items-center justify-center text-gray-300 hover:text-lime transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_40px_rgba(200,217,38,0.15)]">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <!-- LinkedIn -->
          <a href="https://www.linkedin.com/in/ahmet-hamdi-kilic/" target="_blank" rel="noopener noreferrer" class="stagger-item group w-16 h-16 rounded-2xl bg-dark-800 border border-dark-600 hover:border-lime/30 flex items-center justify-center text-gray-300 hover:text-lime transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_40px_rgba(200,217,38,0.15)]">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <!-- X / Twitter -->
          <a href="https://x.com/kaleciolmam" target="_blank" rel="noopener noreferrer" class="stagger-item group w-16 h-16 rounded-2xl bg-dark-800 border border-dark-600 hover:border-lime/30 flex items-center justify-center text-gray-300 hover:text-lime transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_40px_rgba(200,217,38,0.15)]">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <!-- Instagram -->
          <a href="https://www.instagram.com/AhmetHamdiKilic" target="_blank" rel="noopener noreferrer" class="stagger-item group w-16 h-16 rounded-2xl bg-dark-800 border border-dark-600 hover:border-lime/30 flex items-center justify-center text-gray-300 hover:text-lime transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_40px_rgba(200,217,38,0.15)]">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Big CTA Email Button -->
      <div class="p-12 sm:p-16 rounded-3xl bg-dark-800 border border-dark-600 relative overflow-hidden reveal-up">
        <div class="absolute top-0 left-0 w-24 h-24 border-t-2 border-l-2 border-lime/20 rounded-tl-3xl"></div>
        <div class="absolute bottom-0 right-0 w-24 h-24 border-b-2 border-r-2 border-lime/20 rounded-br-3xl"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-lime/5 via-transparent to-transparent"></div>

        <div class="relative z-10">
          <div class="w-20 h-20 rounded-2xl bg-lime/10 flex items-center justify-center mx-auto mb-8">
            <svg class="w-10 h-10 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          </div>

          <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
            <span class="bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">{t('contact.title')}</span>
          </h2>
          <p class="text-gray-300 mb-10 max-w-xl mx-auto">{t('contact.subtitle')}</p>

          <a href="mailto:ahmethamdikilic@outlook.de" class="group relative inline-flex items-center gap-3 px-10 py-5 bg-lime text-dark-900 font-semibold rounded-xl hover:bg-lime-light transition-all duration-300 hover:shadow-[0_0_40px_rgba(200,217,38,0.3)] text-lg">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            <span>{t('contact.cta')}</span>
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
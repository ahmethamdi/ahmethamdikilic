---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = [
  {
    key: 'theme',
    icon: `<svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`,
  },
  {
    key: 'app',
    icon: `<svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z"/></svg>`,
  },
  {
    key: 'integration',
    icon: `<svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>`,
  },
  {
    key: 'migration',
    icon: `<svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3"/></svg>`,
  },
  {
    key: 'speed',
    icon: `<svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
  },
  {
    key: 'b2b',
    icon: `<svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>`,
  },
  {
    key: 'checkout',
    icon: `<svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/></svg>`,
  },
  {
    key: 'support',
    icon: `<svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.42 15.17l-5.1 3.06a.563.563 0 01-.82-.63l1.38-5.67-4.4-3.82a.563.563 0 01.32-.97l5.79-.49 2.28-5.36a.562.562 0 011.06 0l2.28 5.36 5.79.49a.563.563 0 01.32.97l-4.4 3.82 1.38 5.67a.563.563 0 01-.82.63l-5.1-3.06z"/></svg>`,
  },
  {
    key: 'seo',
    icon: `<svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>`,
  },
  {
    key: 'metafields',
    icon: `<svg class="w-7 h-7 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/></svg>`,
  },
];
---

<BaseLayout title={t('meta.services.title')} description={t('meta.services.description')}>

  <!-- ════════════════════════════════════════════════════════════════════
       HERO BANNER
       ════════════════════════════════════════════════════════════════════ -->
  <section class="relative pt-32 pb-20 sm:pt-40 sm:pb-24 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/3 -left-32 w-96 h-96 bg-lime/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-lime/3 rounded-full blur-3xl"></div>
      <div class="absolute inset-0 bg-[linear-gradient(rgba(200,217,38,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(200,217,38,0.03)_1px,transparent_1px)] bg-[size:4rem_4rem]"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-lime/10 border border-lime/20 mb-6 reveal-scale">
        <span class="w-1.5 h-1.5 bg-lime rounded-full"></span>
        <span class="text-xs font-medium text-lime uppercase tracking-wider">{t('services.tag')}</span>
      </div>
      <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold mb-6 reveal-up">
        <span class="bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">{t('services.title')}</span>
      </h1>
      <p class="max-w-2xl mx-auto text-gray-300 text-lg reveal-up">{t('services.subtitle')}</p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       SERVICES GRID
       ════════════════════════════════════════════════════════════════════ -->
  <section class="py-24 sm:py-32 relative">
    <div class="max-w-7xl mx-auto px-6 sm:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-container">
        {services.map((service, index) => (
          <div class="stagger-item group p-8 rounded-2xl bg-dark-800 border border-dark-600 hover:border-lime/30 transition-all duration-500 hover:-translate-y-1 relative overflow-hidden">
            <!-- Glow effect on hover -->
            <div class="absolute inset-0 bg-gradient-to-br from-lime/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <div class="relative z-10">
              <!-- Number badge -->
              <div class="absolute top-0 right-0 text-6xl font-bold font-heading text-dark-700 group-hover:text-dark-600 transition-colors select-none">
                {String(index + 1).padStart(2, '0')}
              </div>

              <!-- Icon -->
              <div class="w-14 h-14 rounded-xl bg-lime/10 flex items-center justify-center mb-6 group-hover:bg-lime/20 transition-colors">
                <Fragment set:html={service.icon} />
              </div>

              <!-- Content -->
              <h3 class="font-heading text-xl font-semibold text-white mb-4 group-hover:text-lime transition-colors">
                {t(`services.${service.key}.title` as any)}
              </h3>
              <p class="text-gray-300 leading-relaxed text-sm">
                {t(`services.${service.key}.desc` as any)}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       BOTTOM CTA
       ════════════════════════════════════════════════════════════════════ -->
  <section class="py-24 sm:py-32 relative">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-lime/5 rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 sm:px-8 text-center">
      <div class="p-12 sm:p-16 rounded-3xl bg-dark-800 border border-dark-600 relative overflow-hidden reveal-up">
        <div class="absolute top-0 left-0 w-24 h-24 border-t-2 border-l-2 border-lime/20 rounded-tl-3xl"></div>
        <div class="absolute bottom-0 right-0 w-24 h-24 border-b-2 border-r-2 border-lime/20 rounded-br-3xl"></div>

        <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold mb-6">
          <span class="bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">{t('contact.title')}</span>
        </h2>
        <p class="text-gray-300 mb-10 max-w-xl mx-auto text-lg">{t('contact.subtitle')}</p>
        <a href={getLocalizedPath(lang, '/contact/')} class="group relative inline-flex items-center gap-2 px-10 py-5 bg-lime text-dark-900 font-semibold rounded-xl hover:bg-lime-light transition-all duration-300 hover:shadow-[0_0_40px_rgba(200,217,38,0.3)] text-lg">
          <span>{t('hero.cta.secondary')}</span>
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
  { key: 'nav.home' as const, href: getLocalizedPath(lang, '/') },
  { key: 'nav.about' as const, href: getLocalizedPath(lang, '/about/') },
  { key: 'nav.services' as const, href: getLocalizedPath(lang, '/services/') },
  { key: 'nav.portfolio' as const, href: getLocalizedPath(lang, '/portfolio/') },
  { key: 'nav.blog' as const, href: getLocalizedPath(lang, '/blog/') },
  { key: 'nav.contact' as const, href: getLocalizedPath(lang, '/contact/') },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 w-full z-50 transition-all duration-500" id="main-header">
  <div class="absolute inset-0 bg-dark-900/0 backdrop-blur-0 transition-all duration-500 header-bg"></div>
  <div class="relative max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
    <div class="flex items-center justify-between h-20 lg:h-24">

      <!-- Logo -->
      <a href={getLocalizedPath(lang, '/')} class="flex items-center gap-3 group z-10">
        <img src="/images/ahk-logo.png" alt="AHK Logo" class="w-11 h-11 rounded-xl transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3" />
        <div class="hidden sm:block">
          <span class="font-heading font-bold text-lg text-white tracking-tight">AHK</span>
          <span class="block text-[10px] uppercase tracking-[0.2em] text-lime/80 font-medium -mt-0.5">Shopify Developer</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navItems.map(({ key, href }) => {
          const isActive = currentPath === href || (href !== getLocalizedPath(lang, '/') && currentPath.startsWith(href));
          return (
            <a
              href={href}
              class:list={[
                'relative px-5 py-2 text-[13px] uppercase tracking-[0.15em] font-medium transition-colors duration-300',
                isActive
                  ? 'text-lime'
                  : 'text-gray-300 hover:text-white',
              ]}
            >
              {t(key)}
              {isActive && <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-1 h-1 bg-lime rounded-full" />}
            </a>
          );
        })}
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-3 z-10">
        <LanguageSwitcher />
        <a
          href={getLocalizedPath(lang, '/contact/')}
          class="hidden md:inline-flex items-center gap-2 px-6 py-3 bg-lime text-dark-900 font-heading font-bold text-[13px] uppercase tracking-wider rounded-full hover:bg-lime-light transition-all duration-300 hover:scale-105 hover:shadow-[0_0_30px_rgba(200,217,38,0.4)]"
        >
          {t('nav.cta')}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
        </a>

        <!-- Mobile menu button -->
        <button class="lg:hidden flex flex-col gap-1.5 p-2 relative z-50" id="mobile-menu-btn" aria-label="Toggle menu">
          <span class="w-7 h-[2px] bg-white transition-all duration-500 origin-center menu-line-1"></span>
          <span class="w-7 h-[2px] bg-white transition-all duration-500 menu-line-2"></span>
          <span class="w-5 h-[2px] bg-white transition-all duration-500 origin-center menu-line-3"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="lg:hidden fixed inset-0 bg-dark-900 z-40 flex flex-col items-center justify-center gap-6 opacity-0 pointer-events-none transition-all duration-700" id="mobile-menu">
    <!-- Decorative bg -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-lime/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-lime/3 rounded-full blur-[100px]"></div>

    {navItems.map(({ key, href }, i) => (
      <a
        href={href}
        class="text-4xl sm:text-5xl font-heading font-bold text-white hover:text-lime transition-colors duration-300"
        style={`transition-delay: ${i * 0.05}s`}
      >
        {t(key)}
      </a>
    ))}
    <a href={getLocalizedPath(lang, '/contact/')} class="mt-6 px-10 py-4 bg-lime text-dark-900 font-heading font-bold text-sm uppercase tracking-wider rounded-full hover:bg-lime-light transition-all duration-300">
      {t('nav.cta')}
    </a>
  </div>
</header>

<style>
  .header-scrolled .header-bg {
    background-color: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(24px);
  }
  .header-scrolled {
    box-shadow: 0 1px 0 rgba(200, 217, 38, 0.08);
  }
  .mobile-open .menu-line-1 {
    transform: rotate(45deg) translate(3px, 3px);
  }
  .mobile-open .menu-line-2 {
    opacity: 0;
    transform: translateX(10px);
  }
  .mobile-open .menu-line-3 {
    width: 1.75rem;
    transform: rotate(-45deg) translate(3px, -3px);
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('main-header');

  btn?.addEventListener('click', () => {
    header?.classList.toggle('mobile-open');
    if (menu?.classList.contains('opacity-0')) {
      menu.classList.remove('opacity-0', 'pointer-events-none');
      menu.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
    } else {
      menu?.classList.add('opacity-0', 'pointer-events-none');
      menu?.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
    }
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      header?.classList.remove('mobile-open');
      menu?.classList.add('opacity-0', 'pointer-events-none');
      menu?.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
    });
  });
</script>

---
import { languages, type Lang } from '../../i18n/ui';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname.replace(/^\/(en|tr|de)/, '');

const flagEmoji: Record<string, string> = {
  en: '🇬🇧',
  tr: '🇹🇷',
  de: '🇩🇪',
};
---

<div class="relative" id="lang-switcher">
  <button
    class="flex items-center gap-2 px-3 py-1.5 text-sm text-gray-300 hover:text-white border border-dark-500 rounded-full hover:border-lime/50 transition-all duration-300"
    id="lang-btn"
    aria-label="Select language"
  >
    <span>{flagEmoji[lang]}</span>
    <span class="uppercase font-medium">{lang}</span>
    <svg class="w-3 h-3 transition-transform duration-300" id="lang-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div
    class="absolute right-0 top-full mt-2 bg-dark-800 border border-dark-500 rounded-xl overflow-hidden opacity-0 pointer-events-none transition-all duration-300 translate-y-2 min-w-[140px]"
    id="lang-dropdown"
  >
    {(Object.keys(languages) as Lang[]).map((l) => (
      <a
        href={`/${l}${currentPath || '/'}`}
        class:list={[
          'flex items-center gap-3 px-4 py-2.5 text-sm transition-colors duration-200',
          l === lang
            ? 'text-lime bg-dark-700'
            : 'text-gray-300 hover:text-white hover:bg-dark-700',
        ]}
      >
        <span>{flagEmoji[l]}</span>
        <span>{languages[l]}</span>
      </a>
    ))}
  </div>
</div>

<script>
  const btn = document.getElementById('lang-btn');
  const dropdown = document.getElementById('lang-dropdown');
  const arrow = document.getElementById('lang-arrow');

  btn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !dropdown?.classList.contains('opacity-0');
    if (isOpen) {
      dropdown?.classList.add('opacity-0', 'pointer-events-none', 'translate-y-2');
      dropdown?.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
      arrow?.classList.remove('rotate-180');
    } else {
      dropdown?.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-2');
      dropdown?.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
      arrow?.classList.add('rotate-180');
    }
  });

  document.addEventListener('click', () => {
    dropdown?.classList.add('opacity-0', 'pointer-events-none', 'translate-y-2');
    dropdown?.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
    arrow?.classList.remove('rotate-180');
  });
</script>

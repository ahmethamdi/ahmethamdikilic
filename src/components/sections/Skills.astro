---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { skills, skillCategories } from '../../data/skills';
import type { Lang } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);

const categories = ['shopify', 'frontend', 'backend', 'tools'] as const;
---

<section id="skills" class="relative py-24 sm:py-32">
  <div class="absolute inset-0 bg-dark-800/30"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-lime/10 border border-lime/20 mb-6 reveal-scale">
        <span class="w-1.5 h-1.5 bg-lime rounded-full"></span>
        <span class="text-xs font-medium text-lime uppercase tracking-wider">{t('skills.tag')}</span>
      </div>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl lg:text-5xl text-white mb-4 reveal-up">
        {t('skills.title')}
      </h2>
      <p class="text-gray-300 max-w-2xl mx-auto reveal-up">
        {t('skills.subtitle')}
      </p>
    </div>

    <!-- Skills by category -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 stagger-container">
      {categories.map((cat) => (
        <div class="p-6 rounded-2xl bg-dark-800 border border-dark-600 stagger-item">
          <h3 class="font-heading font-semibold text-lg text-lime mb-6 flex items-center gap-2">
            <span class="w-2 h-2 bg-lime rounded-full"></span>
            {skillCategories[cat][lang]}
          </h3>
          <div class="space-y-4">
            {skills
              .filter((s) => s.category === cat)
              .map((skill) => (
                <div>
                  <div class="flex justify-between mb-1.5">
                    <span class="text-sm font-medium text-white">{skill.name}</span>
                    <span class="text-xs text-gray-400">{skill.level}%</span>
                  </div>
                  <div class="h-1.5 bg-dark-600 rounded-full overflow-hidden">
                    <div
                      class="h-full bg-gradient-to-r from-lime to-emerald rounded-full skill-bar"
                      style={`width: 0%; --target-width: ${skill.level}%;`}
                      data-width={`${skill.level}%`}
                    ></div>
                  </div>
                </div>
              ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll('.skill-bar').forEach((bar) => {
    const width = (bar as HTMLElement).getAttribute('data-width') || '0%';
    gsap.to(bar, {
      width: width,
      duration: 1.5,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: bar,
        start: 'top 90%',
        toggleActions: 'play none none none',
      },
    });
  });
</script>

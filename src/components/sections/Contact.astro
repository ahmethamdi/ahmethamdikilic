---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contact" class="relative py-24 sm:py-32">
  <div class="absolute inset-0 bg-dark-800/30"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-lime/10 border border-lime/20 mb-6 reveal-scale">
        <span class="w-1.5 h-1.5 bg-lime rounded-full"></span>
        <span class="text-xs font-medium text-lime uppercase tracking-wider">{t('contact.tag')}</span>
      </div>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl lg:text-5xl text-white mb-4 reveal-up">
        {t('contact.title')}
      </h2>
      <p class="text-gray-300 max-w-2xl mx-auto reveal-up">
        {t('contact.subtitle')}
      </p>
    </div>

    <!-- Contact Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 stagger-container">
      <!-- Email -->
      <a
        href="mailto:info@ahmethamdikilic.com"
        class="group p-8 rounded-2xl bg-dark-800 border border-dark-600 hover:border-lime/30 transition-all duration-500 hover:-translate-y-1 text-center stagger-item"
      >
        <div class="w-14 h-14 rounded-xl bg-lime/10 flex items-center justify-center text-lime mx-auto mb-5 group-hover:bg-lime/20 transition-colors duration-300">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <p class="text-sm text-gray-400 mb-2">{t('contact.info.email')}</p>
        <p class="text-white font-medium group-hover:text-lime transition-colors duration-300 text-sm break-all">
          info@ahmethamdikilic.com
        </p>
      </a>

      <!-- WhatsApp -->
      <a
        href="https://wa.me/message"
        target="_blank"
        rel="noopener noreferrer"
        class="group p-8 rounded-2xl bg-dark-800 border border-dark-600 hover:border-lime/30 transition-all duration-500 hover:-translate-y-1 text-center stagger-item"
      >
        <div class="w-14 h-14 rounded-xl bg-lime/10 flex items-center justify-center text-lime mx-auto mb-5 group-hover:bg-lime/20 transition-colors duration-300">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </div>
        <p class="text-sm text-gray-400 mb-2">WhatsApp</p>
        <p class="text-white font-medium group-hover:text-lime transition-colors duration-300 text-sm">
          {t('contact.info.available')}
        </p>
      </a>

      <!-- Location -->
      <div class="group p-8 rounded-2xl bg-dark-800 border border-dark-600 hover:border-lime/30 transition-all duration-500 hover:-translate-y-1 text-center stagger-item">
        <div class="w-14 h-14 rounded-xl bg-lime/10 flex items-center justify-center text-lime mx-auto mb-5 group-hover:bg-lime/20 transition-colors duration-300">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <p class="text-sm text-gray-400 mb-2">{t('contact.info.location')}</p>
        <p class="text-white font-medium text-sm">Germany</p>
      </div>

      <!-- Availability -->
      <div class="group p-8 rounded-2xl bg-dark-800 border border-dark-600 hover:border-emerald/30 transition-all duration-500 hover:-translate-y-1 text-center stagger-item">
        <div class="w-14 h-14 rounded-xl bg-emerald/10 flex items-center justify-center text-emerald mx-auto mb-5 group-hover:bg-emerald/20 transition-colors duration-300">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <p class="text-sm text-gray-400 mb-2">{t('contact.info.availability')}</p>
        <p class="text-emerald font-medium text-sm">{t('contact.info.available')}</p>
      </div>
    </div>

    <!-- Big CTA -->
    <div class="mt-16 text-center reveal-up">
      <a
        href="mailto:info@ahmethamdikilic.com"
        class="group inline-flex items-center gap-3 px-10 py-5 bg-lime text-black font-heading font-bold text-lg rounded-full hover:bg-lime-light transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(200,217,38,0.3)]"
      >
        {t('contact.info.email')}: info@ahmethamdikilic.com
        <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
